#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"
REPO_ROOT="$(pwd)"

LOG_FILE="pixil.log"
PIXIL_MATCH='python(3)? .*Pixil\.py'

# Python for ./run test (no sudo). Prefer a venv with pytest installed.
resolve_test_python() {
  local candidates=()
  if [[ -n "${PIXIL_PYTHON:-}" ]]; then
    candidates+=("$PIXIL_PYTHON")
  fi
  candidates+=(
    "$REPO_ROOT/python_venv/bin/python3"
    "$REPO_ROOT/../python_venv/bin/python3"
    "/home/pi/Programming/python_venv/bin/python3"
  )
  local c
  for c in "${candidates[@]}"; do
    if [[ -x "$c" ]] && "$c" -m pytest --version &>/dev/null; then
      echo "$c"
      return 0
    fi
  done
  if python3 -m pytest --version &>/dev/null; then
    echo "python3"
    return 0
  fi
  return 1
}

usage() {
  cat <<'EOF'
run - Pixil runner and controller

USAGE:
  ./run                          Show this help
  ./run <command> [--] [args]    Run a command
  ./run [--] [pixil args...]     (No command) => interactive in foreground

================================================================================
AUTOMATED TESTS (two tiers)
================================================================================

Pixil tests live under tests/. They do not run during normal lightshow use.

  Tier 1 — ./run test
    Fast pytest on pixil_utils (~300+ tests, about 1 second).
    Covers math, conditions, parameters, JIT-off paths, etc.
    No sudo, no LED matrix, safe on any machine.

  Tier 2 — ./run test-scripts
    Fast smokes from tests/scripts/manifest/core.txt (~3 min on Pi, not 20+).
    Default -t is 0:10 per script (was 1:00). Each script self-reports PASS/FAIL
    via PIXIL_TEST_SUMMARY; harness detects tracebacks and golden mismatches.

  ./run test-all
    Tier 1 pytest (~2s), then core manifest + short main-show smokes (main_smoke.txt).

  ./run test-scripts-main
    Only main-show regression smokes (6–8s each, volatile).

  ./run setup-tests
    One-time: install python3-pytest via apt (needed for Tier 1).

More detail: tests/README.md and docs/Pixil_Development_Guide.txt section 8.

--------------------------------------------------------------------------------
GOLDEN FILES (Tier 2 only)
--------------------------------------------------------------------------------

  ./run test-scripts   DEFAULT — recommended daily / after adding scripts
    • Script already has a .hash file  → compare only (leave file unchanged)
    • Script has no .hash yet          → create golden (golden created -> ...)
    • "volatile" scripts in manifest   → run but never use goldens (live clock)

  Example: goldens exist for test A, B, C; D and E are new in the manifest.
    ./run test-scripts  → A,B,C compared; D,E get new .hash files; A,B,C untouched.

  ./run test-scripts -- --update-golden
  PIXIL_TEST_UPDATE_GOLDEN=1 ./run test-scripts
    Overwrite EVERY non-volatile golden. Use only after intentional visual changes.

  ./run test-scripts -- --no-update-missing
    Compare when golden exists; skip scripts with no .hash (no auto-create).

Adding a test script: scripts/testing/your_test.pix + line in manifest/core.txt,
then ./run test-scripts and commit the new golden/*.hash (if not volatile).

================================================================================
COMMANDS
================================================================================

  test, test-scripts, test-all, setup-tests   See AUTOMATED TESTS above
  interactive   Pixil in foreground (attached terminal)
  start, bg       Pixil in background (nohup, log: pixil.log)
  info            Current / recent scripts from pixil.log
  status          Running Pixil PIDs
  stop            Stop Pixil (TERM, then KILL)
  killpython      Emergency: kill Pixil python, optionally all python
  help            This help

DEFAULT PIXIL ARGS (interactive / start / bg when args omitted):
  main/* -t 60:00

PIXIL OPTIONS (pass after -- with interactive / start / bg):
  script[.pix]   One script, or a wildcard like main/*
  -t mm:ss       Run duration per script (e.g. 5:00, 0:30)
  -d LEVEL       Debug output from the Pixil interpreter (default: DEBUG_OFF)
  -q             Real-time queue depth monitor

  Debug levels (-d):
    DEBUG_OFF       No interpreter debug output (default)
    DEBUG_CONCISE   Minimal (script open/close, cleanup, errors)
    DEBUG_SUMMARY   Commands queued, procedures, throttle/fps, flush counts
    DEBUG_VERBOSE   Line-by-line trace (very noisy; use on one script)

  Script print() output always goes to the terminal (interactive) or pixil.log
  (start/bg). Use sync_queue before print in .pix scripts so output matches
  what is on the matrix (see docs/Pixil_Scripting_Guide.txt §16).

  Full Pixil CLI help: sudo python3 Pixil.py --help

EXAMPLES — run lightshows:
  ./run interactive -- main/* -t 5:00 -q
  ./run start -- main/* -t 60:00

EXAMPLES — debug (foreground; output on terminal):
  ./run interactive -- main/Lorenz_Attractor.pix -t 1:00 -d DEBUG_SUMMARY
  ./run interactive -- main/* -t 0:30 -d DEBUG_VERBOSE -q
  ./run -- main/test.pix -t 0:10 -d DEBUG_CONCISE
    (no command => same as interactive)

EXAMPLES — debug (background; output in pixil.log):
  ./run start -- main/* -t 5:00 -d DEBUG_SUMMARY
  tail -f pixil.log

EXAMPLES — tests:
  ./run setup-tests
  ./run test
  ./run test -- -v -k condition
  ./run test-scripts
  ./run test-all

INFO / STATUS / STOP:
  ./run info
  ./run status
  ./run stop

IMPORTANT — wildcards:
  Do NOT type:  main *     (bare * expands to every file in this directory)
  Use:          main/*    (all scripts in scripts/main/)
EOF
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

show_pixil_procs() {
  if pgrep -af "$PIXIL_MATCH" >/dev/null 2>&1; then
    echo "Pixil processes:"
    pgrep -af "$PIXIL_MATCH" | sed 's/^/  /'
    return 0
  else
    echo "No Pixil processes running."
    return 1
  fi
}

pixil_is_running() {
  pgrep -af "$PIXIL_MATCH" >/dev/null 2>&1
}

stop_pixil() {
  local wait_seconds="${1:-3}"

  echo "Stopping Pixil (TERM)..."
  pkill -f "$PIXIL_MATCH" || true
  sleep "$wait_seconds"

  if pixil_is_running; then
    echo "Pixil still running; forcing stop (KILL)..."
    pkill -9 -f "$PIXIL_MATCH" || true
    sleep 1
  fi

  if pixil_is_running; then
    echo "WARNING: Pixil still appears to be running:"
    pgrep -af "$PIXIL_MATCH" | sed 's/^/  /'
    return 1
  fi

  echo "Pixil stopped."
}

killpython_big_hammer() {
  echo "============================================================"
  echo "WARNING: killpython is dangerous."
  echo "Recommended: use './run stop' first."
  echo "============================================================"
  echo

  echo "Python processes (for visibility):"
  ps aux | grep python | grep -v grep || true
  echo

  echo "Killing Pixil python processes..."
  pkill -9 -f "$PIXIL_MATCH" || true
  echo

  echo "Kill ALL python processes? (y/N)"
  read -r ANSWER
  case "${ANSWER,,}" in
    y|yes)
      echo "Killing ALL python processes..."
      pkill -9 python || true
      ;;
    *)
      echo "Skipping global python kill."
      ;;
  esac
}

# Guardrail: if the user accidentally passed a bare '*', explain and exit.
guard_against_bare_star() {
  local a
  for a in "$@"; do
    if [[ "$a" == "*" ]]; then
      echo "ERROR: You passed a bare '*' which expands to every file in this directory."
      echo
      echo "Use one of these instead:"
      echo "  ./run interactive -- main/* -t 5:00 -q"
      echo "  ./run start -- main/* -t 5:00 -q"
      echo
      echo "Or if you truly meant 'all scripts in main', use main/* (no spaces)."
      exit 2
    fi
  done
}

# ------------------------------------------------------------
# Command detection:
# If first arg is a known command, use it.
# Otherwise treat everything as Pixil args and run interactive.
# ------------------------------------------------------------
COMMAND=""
case "${1:-}" in
  help|info|status|stop|killpython|interactive|start|bg|test|test-scripts|test-scripts-main|test-all|setup-tests)
    COMMAND="$1"
    shift
    ;;
  *)
    COMMAND="interactive"
    ;;
esac

# Optional -- boundary
if [[ "${1:-}" == "--" ]]; then
  shift
fi

PASS_ARGS=( "$@" )

# Apply guardrail to the Pixil args we are about to pass along
guard_against_bare_star "${PASS_ARGS[@]}"

# Default args if none provided for interactive/start/bg
if [[ ${#PASS_ARGS[@]} -eq 0 && ( "$COMMAND" == "start" || "$COMMAND" == "bg" || "$COMMAND" == "interactive" ) ]]; then
  PASS_ARGS=( main/* -t 60:00 )
fi

case "$COMMAND" in
  help)
    usage
    ;;

  info)
    # Check if Pixil is actually running
    PIXIL_RUNNING=false
    if pixil_is_running; then
      PIXIL_RUNNING=true
      show_pixil_procs
    else
      echo "No Pixil processes running."
    fi
    echo
    if [[ -f "$LOG_FILE" ]]; then
      # Extract last 10 "Current script:" entries
      SCRIPTS=$(grep "Current script:" "$LOG_FILE" | tail -10)
      if [[ -n "$SCRIPTS" ]]; then
        TOTAL=$(echo "$SCRIPTS" | wc -l)
        echo "=== Recent scripts (last $TOTAL) ==="
        COUNT=1
        while IFS= read -r line; do
          # Extract just the script name from the path
          SCRIPT_PATH=$(echo "$line" | sed 's/Current script: //' | sed 's/\.\.\.$//')
          SCRIPT_NAME=$(basename "$SCRIPT_PATH")
          if [[ $COUNT -eq $TOTAL ]]; then
            if [[ "$PIXIL_RUNNING" == "true" ]]; then
              echo "  ▶ $SCRIPT_NAME  [RUNNING]"
            else
              echo "  ▶ $SCRIPT_NAME  [LAST]"
            fi
          else
            echo "    $SCRIPT_NAME"
          fi
          ((COUNT++))
        done <<< "$SCRIPTS"
      else
        echo "No script history found in log."
      fi
    else
      echo "No log file found ($LOG_FILE)"
    fi
    ;;

  status)
    show_pixil_procs || true
    ;;

  stop)
    [[ "$EUID" -ne 0 ]] && exec sudo "$0" stop
    show_pixil_procs || true
    echo
    stop_pixil 3
    ;;

  killpython)
    [[ "$EUID" -ne 0 ]] && exec sudo "$0" killpython
    killpython_big_hammer
    ;;

  interactive)
    echo "Starting Pixil interactively (foreground)..."
    echo "Command: sudo python3 Pixil.py ${PASS_ARGS[*]}"
    echo
    exec sudo python3 Pixil.py "${PASS_ARGS[@]}"
    ;;

  setup-tests)
    echo "Installing test dependencies (pytest via apt; no venv required)..."
    sudo apt-get update -qq
    sudo apt-get install -y python3-pytest python3-venv
    echo
    echo "Done. Run: ./run test"
    ;;

  test-scripts)
    if ! TEST_PYTHON="$(resolve_test_python 2>/dev/null)"; then
      TEST_PYTHON="python3"
    fi
    echo "Running Tier 2 script smoke tests (sudo, LED matrix)..."
    echo "Manifest: tests/scripts/manifest/core.txt (default -t 0:10)"
    echo
    export PIXIL_SCRIPT_TIME_LIMIT="${PIXIL_SCRIPT_TIME_LIMIT:-0:10}"
    exec "$TEST_PYTHON" tests/scripts/run_script_tests.py "${PASS_ARGS[@]}"
    ;;

  test-scripts-main)
    if ! TEST_PYTHON="$(resolve_test_python 2>/dev/null)"; then
      TEST_PYTHON="python3"
    fi
    echo "Running Tier 2 main-show smokes (short)..."
    echo "Manifest: tests/scripts/manifest/main_smoke.txt"
    echo
    exec "$TEST_PYTHON" tests/scripts/run_script_tests.py \
      --manifest tests/scripts/manifest/main_smoke.txt "${PASS_ARGS[@]}"
    ;;

  test-all)
    if ! TEST_PYTHON="$(resolve_test_python 2>/dev/null)"; then
      TEST_PYTHON="python3"
    fi
    "$0" test || exit 1
    echo
    echo "Running Tier 2 (core + main smokes)..."
    export PIXIL_SCRIPT_TIME_LIMIT="${PIXIL_SCRIPT_TIME_LIMIT:-0:10}"
    exec "$TEST_PYTHON" tests/scripts/run_script_tests.py \
      --manifest tests/scripts/manifest/core.txt \
      --manifest tests/scripts/manifest/main_smoke.txt \
      "${PASS_ARGS[@]}"
    ;;

  test)
    if ! TEST_PYTHON="$(resolve_test_python)"; then
      echo "ERROR: pytest is not installed for any known Python."
      echo
      echo "On Raspberry Pi (no venv needed for ./run test):"
      echo "  ./run setup-tests"
      echo "  # or: sudo apt install -y python3-pytest"
      echo
      echo "Optional venv (only if you prefer pip-managed deps):"
      echo "  python3 -m venv python_venv"
      echo "  python_venv/bin/pip install -r requirement.txt"
      echo
      echo "Note: Pixil still uses 'sudo python3' for the LED matrix."
      echo "      Unit tests do not need sudo or rgbmatrix."
      exit 1
    fi
    echo "Running automated tests (tests/pixil — no LED hardware)..."
    echo "Python:  $TEST_PYTHON"
    echo "Command: $TEST_PYTHON -m pytest tests/pixil ${PASS_ARGS[*]}"
    echo
    exec "$TEST_PYTHON" -m pytest tests/pixil "${PASS_ARGS[@]}"
    ;;

  start|bg)
    echo "Starting Pixil in background..."
    echo "Command: sudo nohup python3 -u Pixil.py ${PASS_ARGS[*]} > $LOG_FILE 2>&1 &"
    sudo nohup python3 -u Pixil.py "${PASS_ARGS[@]}" > "$LOG_FILE" 2>&1 &
    sleep 1
    show_pixil_procs || true
    echo "Log: $LOG_FILE"
    ;;

  *)
    echo "Unknown command: $COMMAND"
    echo
    usage
    exit 2
    ;;
esac

