# ============================================
# WHILE 8: While with NOT on parenthesized group
# ============================================
print("WHILE 8: While with NOT on paren group (not (v_cc > 2 and v_dd > 2))")
v_while8_passed = 0
v_cc = 0
v_dd = 0
while not (v_cc > 2 and v_dd > 2) then
    v_cc = v_cc + 1
    v_dd = v_dd + 1
    if v_cc > 5 then
        # Safety break to prevent infinite loop
        v_cc = 10
        v_dd = 10
    endif
endwhile
if v_cc == 3 then
    print("  PASS: While with NOT on paren group worked (expected)")
    v_while8_passed = 1
else
    print("  FAIL: While with NOT on paren group failed (unexpected)")
endif

