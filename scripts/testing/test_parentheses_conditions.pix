# Test script for Level 2 Parentheses Support in Conditions
# Tests various parentheses combinations in if/then/else statements
# Also includes regression tests for legacy syntax (no parentheses)

print("=== Testing Parentheses in Conditions ===")
print("")

# Setup test variables
v_x = 10
v_y = 5
v_z = 15
v_a = 1
v_b = 0

# ============================================
# REGRESSION TESTS - Legacy Syntax (No Parentheses)
# These must continue to work as before
# ============================================
print("--- REGRESSION TESTS (Legacy Syntax) ---")
print("")

# ============================================
# LEGACY 1: Simple condition
# v_x > 5
# Expected: true
# ============================================
print("LEGACY 1: v_x > 5")
v_legacy1_passed = 0
if v_x > 5 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_legacy1_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# LEGACY 2: Simple condition with ==
# v_z == 15
# Expected: true
# ============================================
print("LEGACY 2: v_z == 15")
v_legacy2_passed = 0
if v_z == 15 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_legacy2_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# LEGACY 3: Simple AND compound
# v_x > 5 and v_y < 10
# Expected: true and true = true
# ============================================
print("LEGACY 3: v_x > 5 and v_y < 10")
v_legacy3_passed = 0
if v_x > 5 and v_y < 10 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_legacy3_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# LEGACY 4: Simple OR compound
# v_x > 100 or v_y < 10
# Expected: false or true = true
# ============================================
print("LEGACY 4: v_x > 100 or v_y < 10")
v_legacy4_passed = 0
if v_x > 100 or v_y < 10 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_legacy4_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# LEGACY 5: AND with OR (default precedence: AND > OR)
# v_a == 1 or v_b == 1 and v_z == 0
# Should be: v_a == 1 or (v_b == 1 and v_z == 0) = true or (false and false) = true or false = true
# ============================================
print("LEGACY 5: v_a == 1 or v_b == 1 and v_z == 0")
v_legacy5_passed = 0
if v_a == 1 or v_b == 1 and v_z == 0 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_legacy5_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# LEGACY 6: Multiple ANDs
# v_x > 5 and v_y < 10 and v_z == 15
# Expected: true and true and true = true
# ============================================
print("LEGACY 6: v_x > 5 and v_y < 10 and v_z == 15")
v_legacy6_passed = 0
if v_x > 5 and v_y < 10 and v_z == 15 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_legacy6_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# LEGACY 7: Multiple ORs
# v_x > 100 or v_y > 100 or v_z == 15
# Expected: false or false or true = true
# ============================================
print("LEGACY 7: v_x > 100 or v_y > 100 or v_z == 15")
v_legacy7_passed = 0
if v_x > 100 or v_y > 100 or v_z == 15 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_legacy7_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# LEGACY 8: Boolean variable as condition
# v_a (truthy value 1)
# Expected: true
# ============================================
print("LEGACY 8: v_a (truthy value)")
v_legacy8_passed = 0
if v_a then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_legacy8_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# LEGACY 9: Boolean variable as condition (falsy)
# v_b (falsy value 0)
# Expected: false
# ============================================
print("LEGACY 9: v_b (falsy value)")
v_legacy9_passed = 0
if v_b then
    print("  FAIL: Condition evaluated to TRUE (unexpected)")
else
    print("  PASS: Condition evaluated to FALSE (expected)")
    v_legacy9_passed = 1
endif

# ============================================
# LEGACY 10: Not equal operator
# v_x != 5
# Expected: true (v_x is 10)
# ============================================
print("LEGACY 10: v_x != 5")
v_legacy10_passed = 0
if v_x != 5 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_legacy10_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# LEGACY 11: Less than or equal
# v_y <= 5
# Expected: true (v_y is 5)
# ============================================
print("LEGACY 11: v_y <= 5")
v_legacy11_passed = 0
if v_y <= 5 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_legacy11_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# LEGACY 12: Greater than or equal
# v_x >= 10
# Expected: true (v_x is 10)
# ============================================
print("LEGACY 12: v_x >= 10")
v_legacy12_passed = 0
if v_x >= 10 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_legacy12_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

print("")
print("--- NEW FEATURE TESTS (Parentheses) ---")
print("")

# ============================================
# TEST 1: Single parenthesized group with OR, combined with AND
# (v_x > 5 or v_y < 2) and v_z == 15
# Expected: (true or false) and true = true and true = true
# ============================================
print("TEST 1: (v_x > 5 or v_y < 2) and v_z == 15")
v_test1_passed = 0
if (v_x > 5 or v_y < 2) and v_z == 15 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_test1_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# TEST 2: Single parenthesized group with AND, combined with OR
# (v_x > 20 and v_y < 2) or v_z == 15
# Expected: (false and false) or true = false or true = true
# ============================================
print("TEST 2: (v_x > 20 and v_y < 2) or v_z == 15")
v_test2_passed = 0
if (v_x > 20 and v_y < 2) or v_z == 15 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_test2_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# TEST 3: Two parenthesized groups with OR
# (v_x > 5 and v_y < 10) or (v_z == 0)
# Expected: (true and true) or false = true or false = true
# ============================================
print("TEST 3: (v_x > 5 and v_y < 10) or (v_z == 0)")
v_test3_passed = 0
if (v_x > 5 and v_y < 10) or (v_z == 0) then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_test3_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# TEST 4: Two parenthesized groups with AND
# (v_x > 5) and (v_z == 15)
# Expected: true and true = true
# ============================================
print("TEST 4: (v_x > 5) and (v_z == 15)")
v_test4_passed = 0
if (v_x > 5) and (v_z == 15) then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_test4_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# TEST 5: Parentheses changing precedence
# Without parens: v_a == 1 or v_b == 1 and v_z == 0
# Would be: v_a == 1 or (v_b == 1 and v_z == 0) = true or false = true
# With parens: (v_a == 1 or v_b == 1) and v_z == 0
# Expected: (true or false) and false = true and false = false
# ============================================
print("TEST 5: (v_a == 1 or v_b == 1) and v_z == 0")
v_test5_passed = 0
if (v_a == 1 or v_b == 1) and v_z == 0 then
    print("  FAIL: Condition evaluated to TRUE (unexpected)")
else
    print("  PASS: Condition evaluated to FALSE (expected)")
    v_test5_passed = 1
endif

# ============================================
# TEST 6: Three parenthesized groups
# (v_x > 5) or (v_y > 100) or (v_z == 15)
# Expected: true or false or true = true
# ============================================
print("TEST 6: (v_x > 5) or (v_y > 100) or (v_z == 15)")
v_test6_passed = 0
if (v_x > 5) or (v_y > 100) or (v_z == 15) then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_test6_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# TEST 7: Mixed - simple condition AND parenthesized group
# v_a == 1 and (v_x > 5 or v_y > 100)
# Expected: true and (true or false) = true and true = true
# ============================================
print("TEST 7: v_a == 1 and (v_x > 5 or v_y > 100)")
v_test7_passed = 0
if v_a == 1 and (v_x > 5 or v_y > 100) then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_test7_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# TEST 8: Complex - two groups with compound conditions
# (v_x > 5 and v_y < 10) or (v_z > 10 and v_a == 1)
# Expected: (true and true) or (true and true) = true or true = true
# ============================================
print("TEST 8: (v_x > 5 and v_y < 10) or (v_z > 10 and v_a == 1)")
v_test8_passed = 0
if (v_x > 5 and v_y < 10) or (v_z > 10 and v_a == 1) then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_test8_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# TEST 9: Verify FALSE case works too
# (v_x > 100) and (v_y > 100)
# Expected: false and false = false
# ============================================
print("TEST 9: (v_x > 100) and (v_y > 100)")
v_test9_passed = 0
if (v_x > 100) and (v_y > 100) then
    print("  FAIL: Condition evaluated to TRUE (unexpected)")
else
    print("  PASS: Condition evaluated to FALSE (expected)")
    v_test9_passed = 1
endif

# ============================================
# SUMMARY
# ============================================
print("")
print("=== TEST SUMMARY ===")

# Legacy regression tests
v_legacy_passed = v_legacy1_passed + v_legacy2_passed + v_legacy3_passed + v_legacy4_passed + v_legacy5_passed + v_legacy6_passed + v_legacy7_passed + v_legacy8_passed + v_legacy9_passed + v_legacy10_passed + v_legacy11_passed + v_legacy12_passed
print(f"Legacy regression tests: {v_legacy_passed} / 12")

# New parentheses feature tests
v_paren_passed = v_test1_passed + v_test2_passed + v_test3_passed + v_test4_passed + v_test5_passed + v_test6_passed + v_test7_passed + v_test8_passed + v_test9_passed
print(f"Parentheses feature tests: {v_paren_passed} / 9")

# Total
v_total_passed = v_legacy_passed + v_paren_passed
v_total_tests = 21
print(f"Total tests passed: {v_total_passed} / {v_total_tests}")

print("")
if v_total_passed == v_total_tests then
    print("ALL TESTS PASSED!")
else
    print("SOME TESTS FAILED - review output above")
    if v_legacy_passed != 12 then
        print("WARNING: Legacy regression tests failed - existing functionality may be broken!")
    endif
endif

print("")
print("=== End of Condition Tests ===")
