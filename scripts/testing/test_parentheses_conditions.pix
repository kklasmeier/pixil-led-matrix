print("")
print("--- NOT OPERATOR TESTS ---")
print("")

# Reset test variables for NOT tests
v_flag = 1
v_disabled = 0
v_active = 1

# ============================================
# NOT 1: Negate a truthy boolean variable
# not v_flag (where v_flag = 1)
# Expected: not true = false
# ============================================
print("NOT 1: not v_flag (v_flag=1, truthy)")
v_not1_passed = 0
if not v_flag then
    print("  FAIL: Condition evaluated to TRUE (unexpected)")
else
    print("  PASS: Condition evaluated to FALSE (expected)")
    v_not1_passed = 1
endif

# ============================================
# NOT 2: Negate a falsy boolean variable
# not v_disabled (where v_disabled = 0)
# Expected: not false = true
# ============================================
print("NOT 2: not v_disabled (v_disabled=0, falsy)")
v_not2_passed = 0
if not v_disabled then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_not2_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# NOT 3: Negate a comparison (not v_x > 100)
# v_x = 10, so v_x > 100 is false, not false = true
# ============================================
print("NOT 3: not v_x > 100 (v_x=10)")
v_not3_passed = 0
if not v_x > 100 then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_not3_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# NOT 4: Negate a true comparison (not v_x > 5)
# v_x = 10, so v_x > 5 is true, not true = false
# ============================================
print("NOT 4: not v_x > 5 (v_x=10)")
v_not4_passed = 0
if not v_x > 5 then
    print("  FAIL: Condition evaluated to TRUE (unexpected)")
else
    print("  PASS: Condition evaluated to FALSE (expected)")
    v_not4_passed = 1
endif

# ============================================
# NOT 5: Negate a parenthesized group
# not (v_x > 5 and v_y < 10)
# v_x=10, v_y=5: (true and true) = true, not true = false
# ============================================
print("NOT 5: not (v_x > 5 and v_y < 10)")
v_not5_passed = 0
if not (v_x > 5 and v_y < 10) then
    print("  FAIL: Condition evaluated to TRUE (unexpected)")
else
    print("  PASS: Condition evaluated to FALSE (expected)")
    v_not5_passed = 1
endif

# ============================================
# NOT 6: NOT combined with AND
# v_a == 1 and not v_disabled
# v_a=1 (true), v_disabled=0 (false), not false = true
# true and true = true
# ============================================
print("NOT 6: v_a == 1 and not v_disabled")
v_not6_passed = 0
if v_a == 1 and not v_disabled then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_not6_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# NOT 7: NOT combined with OR
# v_x > 100 or not v_disabled
# false or not false = false or true = true
# ============================================
print("NOT 7: v_x > 100 or not v_disabled")
v_not7_passed = 0
if v_x > 100 or not v_disabled then
    print("  PASS: Condition evaluated to TRUE (expected)")
    v_not7_passed = 1
else
    print("  FAIL: Condition evaluated to FALSE (unexpected)")
endif

# ============================================
# NOT 8: Multiple NOT operators
# not v_disabled and not v_b
# v_disabled=0, v_b=0: not false and not false = true and true = true
# ============================================
