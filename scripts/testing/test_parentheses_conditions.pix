print("")
print("--- WHILE LOOP CONDITION TESTS ---")

# ============================================
# WHILE 1: Basic while condition
# ============================================
print("WHILE 1: Basic while condition (v_count < 3)")
v_while1_passed = 0
v_count = 0
while v_count < 3 then
    v_count = v_count + 1
endwhile
if v_count == 3 then
    print("  PASS: Basic while loop worked (expected)")
    v_while1_passed = 1
else
    print("  FAIL: Basic while loop failed (unexpected)")
endif

# ============================================
# WHILE 2: While with compound AND
# ============================================
print("WHILE 2: While with compound AND (v_i < 5 and v_flag == 1)")
v_while2_passed = 0
v_i = 0
v_flag = 1
while v_i < 5 and v_flag == 1 then
    v_i = v_i + 1
    if v_i >= 3 then
        v_flag = 0
    endif
endwhile
if v_i == 3 then
    print("  PASS: While with AND worked (expected)")
    v_while2_passed = 1
else
    print("  FAIL: While with AND failed (unexpected)")
endif

# ============================================
# WHILE 3: While with compound OR
# ============================================
print("WHILE 3: While with compound OR (v_j < 2 or v_k < 2)")
v_while3_passed = 0
v_j = 0
v_k = 0
v_iterations = 0
while v_j < 2 or v_k < 2 then
    v_iterations = v_iterations + 1
    if v_j < 2 then
        v_j = v_j + 1
    endif
    if v_k < 2 then
        v_k = v_k + 1
    endif
endwhile
if v_iterations == 2 then
    print("  PASS: While with OR worked (expected)")
    v_while3_passed = 1
else
    print("  FAIL: While with OR failed (unexpected)")
endif

# ============================================
# WHILE 4: While with NOT
# ============================================
print("WHILE 4: While with NOT (not v_done)")
v_while4_passed = 0
v_done = 0
v_loop_count = 0
while not v_done then
    v_loop_count = v_loop_count + 1
    if v_loop_count >= 3 then
        v_done = 1
    endif
endwhile
if v_loop_count == 3 then
    print("  PASS: While with NOT worked (expected)")
    v_while4_passed = 1
else
    print("  FAIL: While with NOT failed (unexpected)")
endif

