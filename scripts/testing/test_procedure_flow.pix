# Tier 2: procedures with if/elseif/else; call from main, if, and for
# Uses global v_mode / v_x (same pattern as main/snake scripts).

clear()
v_run = 1

def mark_at_mode {
    if v_mode == 1 then
        plot(v_x, 10, red, 100)
    elseif v_mode == 2 then
        plot(v_x, 26, green, 100)
    else
        plot(v_x, 42, blue, 100)
    endif
}

v_mode = 1
v_x = 8
call mark_at_mode

if v_run == 1 then
    v_mode = 3
    v_x = 44
    call mark_at_mode
endif

for v_i in (1, 3, 1)
    v_mode = 2
    v_x = v_i * 12
    call mark_at_mode
endfor v_i
