# Test script for Fast Math Optimizations
# Run with: python Pixil.py scripts/testing/test_fast_math_optimizations.pix

# Initialize test variables
v_a = 10
v_b = 3
v_c = 20
v_d = 4
v_angle_deg = 90
v_rad_value = 1.5708
v_sqrt_input = 16
v_rand_min = 0
v_rand_max = 100

# Colors
v_green = 32
v_cyan = 28

# TEST 1: var - var
v_result1 = v_a - v_b
plot(0, 0, v_green)

# TEST 2: var / var
v_result2 = v_c / v_d
plot(1, 0, v_green)

# TEST 3: num + var
v_result3 = 5 + v_a
plot(2, 0, v_green)

# TEST 4: num - var
v_result4 = 20 - v_a
plot(3, 0, v_green)

# TEST 5: num * var
v_result5 = 3 * v_a
plot(4, 0, v_green)

# TEST 6: num / var
v_result6 = 100 / v_a
plot(5, 0, v_green)

# TEST 7: random with literals
v_result7 = random(0, 100, 0)
plot(6, 0, v_green)

# TEST 8: random with variables
v_result8 = random(v_rand_min, v_rand_max, 0)
plot(7, 0, v_green)

# TEST 9: radians with literal
v_result9 = radians(180)
plot(0, 1, v_green)

# TEST 10: radians with variable
v_result10 = radians(v_angle_deg)
plot(1, 1, v_green)

# TEST 11: sin with literal
v_result11 = sin(0)
plot(2, 1, v_green)

# TEST 12: sin with variable
v_result12 = sin(v_rad_value)
plot(3, 1, v_green)

# TEST 13: cos with literal
v_result13 = cos(0)
plot(4, 1, v_green)

# TEST 14: cos with variable
v_result14 = cos(v_rad_value)
plot(5, 1, v_green)

# TEST 15: sqrt with literal
v_result15 = sqrt(25)
plot(6, 1, v_green)

# TEST 16: sqrt with variable
v_result16 = sqrt(v_sqrt_input)
plot(7, 1, v_green)

# Stress test loop - exercises fast paths repeatedly
for v_i in (0, 99, 1)
    v_diff = v_a - v_b
    v_sum = 10 + v_i
    v_angle = v_i * 3.6
    v_rad = radians(v_angle)
    v_sin_val = sin(v_rad)
    v_cos_val = cos(v_rad)
    v_px = 32 + v_sin_val * 20
    v_py = 32 + v_cos_val * 20
    plot(v_px, v_py, v_cyan)
endfor v_i

# Draw border
draw_rectangle(0, 0, 9, 3, 7, 100, false)

rest(3)
