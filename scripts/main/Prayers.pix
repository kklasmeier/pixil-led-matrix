# ============================================================================
# PRAYER SELECTION
# ============================================================================
def select_prayer {
    if v_debug_prayer >= 0 then
        v_selected = v_debug_prayer
    else
        v_selected = random(0, v_num_prayers - 1, 0)
    endif
}

def run_selected_prayer {
    if v_selected == 0 then
        print("Selected: Our Father")
        call setup_our_father
    elseif v_selected == 1 then
        print("Selected: Glory Be")
        call setup_glory_be
    elseif v_selected == 2 then
        print("Selected: Hail Mary")
        call setup_hail_mary
    elseif v_selected == 3 then
        print("Selected: Nicene Creed")
        call setup_nicene_creed
    elseif v_selected == 4 then
        print("Selected: Act of Contrition")
        call setup_act_of_contrition
    elseif v_selected == 5 then
        print("Selected: Angel of God")
        call setup_angel_of_god
    elseif v_selected == 6 then
        print("Selected: Grace Before Meals")
        call setup_grace_before_meals
    elseif v_selected == 7 then
        print("Selected: St. Michael Prayer")
        call setup_st_michael
    elseif v_selected == 8 then
        print("Selected: Apostles' Creed")
        call setup_apostles_creed
    elseif v_selected == 9 then
        print("Selected: Fatima Prayer")
        call setup_fatima_prayer
    elseif v_selected == 10 then
        print("Selected: Gloria")
        call setup_gloria
    elseif v_selected == 11 then
        print("Selected: Confiteor")
        call setup_confiteor
    else
        print("Selected: Divine Mercy Chaplet")
        call setup_divine_mercy
    endif
    call display_prayer
}

# ============================================================================
# MAIN PROGRAM
# ============================================================================
clear()
call setup_colors

while 1 then
    call select_prayer
    call run_selected_prayer
    rest(2)
    clear()
endwhile
