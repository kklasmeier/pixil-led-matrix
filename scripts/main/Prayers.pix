# Prayer Display Script
# Roman Catholic Prayers: Our Father, Glory Be, Hail Mary, Nicene Creed

# ============================================================================
# DEBUG SETTINGS
# ============================================================================
# Set to -1 for random prayer selection
# Set to 0-12 to force a specific prayer (see list below)
v_debug_prayer = -1
v_num_prayers = 13

# Prayer Index:
#  0 = Our Father
#  1 = Glory Be
#  2 = Hail Mary
#  3 = Nicene Creed
#  4 = Act of Contrition
#  5 = Angel of God
#  6 = Grace Before Meals
#  7 = St. Michael Prayer
#  8 = Apostles' Creed
#  9 = Fatima Prayer
# 10 = Gloria
# 11 = Confiteor
# 12 = Divine Mercy Chaplet

# ============================================================================
# INITIALIZATION
# ============================================================================
v_max_words = 250
create_array(v_words, v_max_words, string)
create_array(v_delays, v_max_words, numeric)
create_array(v_prayer_names, v_num_prayers, string)

v_prayer_names[0] = "Our Father"
v_prayer_names[1] = "Glory Be"
v_prayer_names[2] = "Hail Mary"
v_prayer_names[3] = "Nicene Creed"
v_prayer_names[4] = "Act of Contrition"
v_prayer_names[5] = "Angel of God"
v_prayer_names[6] = "Grace Before Meals"
v_prayer_names[7] = "St. Michael"
v_prayer_names[8] = "Apostles' Creed"
v_prayer_names[9] = "Fatima Prayer"
v_prayer_names[10] = "Gloria"
v_prayer_names[11] = "Confiteor"
v_prayer_names[12] = "Divine Mercy"

# ============================================================================
# COLOR SETUP
# ============================================================================
def setup_colors {
    create_array(v_colors, 15, string)
    v_colors[0] = "white"
    v_colors[1] = "sky_blue"
    v_colors[2] = "gold"
    v_colors[3] = "spring_green"
    v_colors[4] = "violet"
    v_colors[5] = "rose"
    v_colors[6] = "azure"
    v_colors[7] = "cyan"
    v_colors[8] = "lavender"
    v_colors[9] = "silver"
    v_colors[10] = "peach"
    v_colors[11] = "mint"
    v_colors[12] = "coral"
    v_colors[13] = "turquoise"
    v_colors[14] = "light_gray"
}

def get_random_color {
    v_color_index = random(0, 14, 0)
    v_color = v_colors[v_color_index]
}

# ============================================================================
# DISPLAY PROCEDURES
# ============================================================================
def display_prayer_name {
    draw_text(62, 0, v_prayer_name, tiny64_font, 8, gray, 60, NORMAL, RIGHT)
}

def display_virtually_centered {
    v_y = 32
    for v_i in (0, v_word_count - 1, 1)
        begin_frame
        call display_prayer_name
        if v_center_align == 1 then
            draw_text(32, v_y, v_words[v_i], piboto-regular, v_text_size, v_color, 100, NORMAL, CENTER)
        else
            draw_text(1, v_y, v_words[v_i], piboto-regular, v_text_size, v_color)
        endif
        end_frame
        rest(v_delays[v_i])
        sync_queue
    endfor v_i
}

def display_random_vertical {
    v_bottom_margin = v_text_size
    v_max_y = 59 - v_bottom_margin
    for v_i in (0, v_word_count - 1, 1)
        begin_frame
        call display_prayer_name
        v_y = random(0, v_max_y, 0)
        if v_center_align == 1 then
            draw_text(32, v_y, v_words[v_i], piboto-regular, v_text_size, v_color, 100, NORMAL, CENTER)
        else
            draw_text(1, v_y, v_words[v_i], piboto-regular, v_text_size, v_color)
        endif
        end_frame
        rest(v_delays[v_i])
        sync_queue
    endfor v_i
}

def display_top_to_bottom {
    v_step = 1
    v_bottom_margin = v_text_size
    v_max_y = 59 - v_bottom_margin
    v_y = 0
    for v_i in (0, v_word_count - 1, 1)
        begin_frame
        call display_prayer_name
        v_y = v_y + v_step
        if v_y > v_max_y then
            v_y = 0
        endif
        if v_center_align == 1 then
            draw_text(32, v_y, v_words[v_i], piboto-regular, v_text_size, v_color, 100, NORMAL, CENTER)
        else
            draw_text(1, v_y, v_words[v_i], piboto-regular, v_text_size, v_color)
        endif
        end_frame
        rest(v_delays[v_i])
        sync_queue
    endfor v_i
}

def display_quarter_drops {
    v_quarter = 16
    v_bottom_margin = v_text_size
    v_max_y = 59 - v_bottom_margin
    v_y = 0
    for v_i in (0, v_word_count - 1, 1)
        begin_frame
        call display_prayer_name
        v_y = v_y + v_quarter
        if v_y > v_max_y then
            v_y = 0
        endif
        if v_center_align == 1 then
            draw_text(32, v_y, v_words[v_i], piboto-regular, v_text_size, v_color, 100, NORMAL, CENTER)
        else
            draw_text(1, v_y, v_words[v_i], piboto-regular, v_text_size, v_color)
        endif
        end_frame
        rest(v_delays[v_i])
        sync_queue
    endfor v_i
}

def display_prayer {
    v_style = random(0, 3, 0)
    v_center_align = random(0, 1, 0)
    call get_random_color
    
    if v_style == 0 then
        call display_virtually_centered
    elseif v_style == 1 then
        call display_random_vertical
    elseif v_style == 2 then
        call display_top_to_bottom
    else
        call display_quarter_drops
    endif
}

