        draw_polygon(71, 31, 7, 4, spring_green, 60, 45, false)
        draw_polygon(71, 31, 3, 4, white, 75, 45, true)
        
        draw_polygon(11, 51, 7, 4, green, 55, 45, false)
        draw_polygon(11, 51, 3, 4, lime, 65, 45, true)
        
        draw_polygon(31, 51, 7, 4, lime, 50, 45, false)
        draw_polygon(31, 51, 3, 4, green, 60, 45, true)
        
        draw_polygon(51, 51, 7, 4, green, 55, 45, false)
