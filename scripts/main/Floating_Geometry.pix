# ============================================================
# FLOATING GEOMETRY - Single layer with morphing patterns
# ============================================================
# Background drifts fluidly in all directions
# Multiple cels transition between different color/shape schemes
# ============================================================

throttle(0)

# ============================================================
# BACKGROUND: MULTI-CEL PATTERN VARIATIONS
# Each cel is a different visual theme
# ============================================================
define_sprite(geo_pattern, 80, 80)

    # ----------------------------------------------------------
    # CEL 0: CYAN/MAGENTA - Squares with circles
    # ----------------------------------------------------------
    sprite_cel(0)
        draw_rectangle(4, 4, 14, 14, cyan, 50, false)
        draw_circle(11, 11, 4, magenta, 60, false)
        plot(11, 11, white, 75)
        
        draw_rectangle(24, 4, 14, 14, magenta, 45, false)
        draw_circle(31, 11, 4, cyan, 55, false)
        plot(31, 11, white, 70)
        
        draw_rectangle(44, 4, 14, 14, cyan, 50, false)
        draw_circle(51, 11, 4, magenta, 60, false)
        plot(51, 11, white, 75)
        
        draw_rectangle(64, 4, 14, 14, magenta, 45, false)
        draw_circle(71, 11, 4, cyan, 55, false)
        plot(71, 11, white, 70)
        
        draw_rectangle(4, 24, 14, 14, magenta, 45, false)
        draw_circle(11, 31, 4, cyan, 55, false)
        plot(11, 31, white, 70)
        
        draw_rectangle(24, 24, 14, 14, cyan, 55, false)
