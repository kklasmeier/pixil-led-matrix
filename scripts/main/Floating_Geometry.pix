        draw_polygon(71, 51, 7, 4, lime, 50, 45, false)
        draw_polygon(71, 51, 3, 4, green, 60, 45, true)
        
        draw_polygon(11, 71, 7, 4, lime, 50, 45, false)
        draw_polygon(11, 71, 3, 4, green, 60, 45, true)
        
        draw_polygon(31, 71, 7, 4, spring_green, 60, 45, false)
        draw_polygon(31, 71, 3, 4, white, 75, 45, true)
        
        draw_polygon(51, 71, 7, 4, lime, 50, 45, false)
        draw_polygon(51, 71, 3, 4, green, 60, 45, true)
        
        draw_polygon(71, 71, 7, 4, spring_green, 60, 45, false)
        draw_polygon(71, 71, 3, 4, white, 75, 45, true)

    # ----------------------------------------------------------
    # CEL 2: ORANGE/GOLD - Hexagons with centers
    # ----------------------------------------------------------
    sprite_cel(2)
        draw_polygon(11, 11, 7, 6, orange, 55, 0, false)
        draw_circle(11, 11, 3, gold, 65, true)
        
        draw_polygon(31, 11, 7, 6, gold, 50, 30, false)
