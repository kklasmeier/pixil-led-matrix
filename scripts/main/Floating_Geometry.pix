        draw_polygon(51, 11, 7, 4, green, 55, 45, false)
        draw_polygon(51, 11, 3, 4, lime, 65, 45, true)
        
        draw_polygon(71, 11, 7, 4, lime, 50, 45, false)
        draw_polygon(71, 11, 3, 4, green, 60, 45, true)
        
        draw_polygon(11, 31, 7, 4, lime, 50, 45, false)
