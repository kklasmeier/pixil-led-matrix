        draw_polygon(71, 11, 7, 6, gold, 50, 30, false)
        draw_circle(71, 11, 3, orange, 60, true)
        
        draw_polygon(11, 31, 7, 6, gold, 50, 30, false)
        draw_circle(11, 31, 3, orange, 60, true)
        
        draw_polygon(31, 31, 7, 6, yellow, 60, 0, false)
        draw_circle(31, 31, 3, white, 75, true)
        
        draw_polygon(51, 31, 7, 6, gold, 50, 30, false)
        draw_circle(51, 31, 3, orange, 60, true)
        
        draw_polygon(71, 31, 7, 6, yellow, 60, 0, false)
        draw_circle(71, 31, 3, white, 75, true)
        
        draw_polygon(11, 51, 7, 6, orange, 55, 0, false)
        draw_circle(11, 51, 3, gold, 65, true)
        
        draw_polygon(31, 51, 7, 6, gold, 50, 30, false)
        draw_circle(31, 51, 3, orange, 60, true)
        
        draw_polygon(51, 51, 7, 6, orange, 55, 0, false)
        draw_circle(51, 51, 3, gold, 65, true)
        
        draw_polygon(71, 51, 7, 6, gold, 50, 30, false)
        draw_circle(71, 51, 3, orange, 60, true)
        
        draw_polygon(11, 71, 7, 6, gold, 50, 30, false)
        draw_circle(11, 71, 3, orange, 60, true)
        
        draw_polygon(31, 71, 7, 6, yellow, 60, 0, false)
        draw_circle(31, 71, 3, white, 75, true)
        
        draw_polygon(51, 71, 7, 6, gold, 50, 30, false)
        draw_circle(51, 71, 3, orange, 60, true)
        
        draw_polygon(71, 71, 7, 6, yellow, 60, 0, false)
        draw_circle(71, 71, 3, white, 75, true)

    # ----------------------------------------------------------
    # CEL 3: BLUE/PURPLE - Concentric rings
    # ----------------------------------------------------------
    sprite_cel(3)
        draw_circle(11, 11, 7, blue, 45, false)
        draw_circle(11, 11, 4, purple, 55, false)
        plot(11, 11, cyan, 70)
        
        draw_circle(31, 11, 7, purple, 40, false)
        draw_circle(31, 11, 4, blue, 50, false)
        plot(31, 11, cyan, 65)
        
        draw_circle(51, 11, 7, blue, 45, false)
        draw_circle(51, 11, 4, purple, 55, false)
        plot(51, 11, cyan, 70)
        
        draw_circle(71, 11, 7, purple, 40, false)
        draw_circle(71, 11, 4, blue, 50, false)
        plot(71, 11, cyan, 65)
        
        draw_circle(11, 31, 7, purple, 40, false)
        draw_circle(11, 31, 4, blue, 50, false)
        plot(11, 31, cyan, 65)
        
        draw_circle(31, 31, 7, violet, 55, false)
        draw_circle(31, 31, 4, sky_blue, 65, false)
        plot(31, 31, white, 80)
        
        draw_circle(51, 31, 7, purple, 40, false)
        draw_circle(51, 31, 4, blue, 50, false)
        plot(51, 31, cyan, 65)
        
        draw_circle(71, 31, 7, violet, 55, false)
        draw_circle(71, 31, 4, sky_blue, 65, false)
        plot(71, 31, white, 80)
        
        draw_circle(11, 51, 7, blue, 45, false)
        draw_circle(11, 51, 4, purple, 55, false)
        plot(11, 51, cyan, 70)
        
        draw_circle(31, 51, 7, purple, 40, false)
        draw_circle(31, 51, 4, blue, 50, false)
        plot(31, 51, cyan, 65)
        
        draw_circle(51, 51, 7, blue, 45, false)
        draw_circle(51, 51, 4, purple, 55, false)
        plot(51, 51, cyan, 70)
        
        draw_circle(71, 51, 7, purple, 40, false)
        draw_circle(71, 51, 4, blue, 50, false)
        plot(71, 51, cyan, 65)
        
        draw_circle(11, 71, 7, purple, 40, false)
        draw_circle(11, 71, 4, blue, 50, false)
        plot(11, 71, cyan, 65)
        
        draw_circle(31, 71, 7, violet, 55, false)
        draw_circle(31, 71, 4, sky_blue, 65, false)
        plot(31, 71, white, 80)
        
        draw_circle(51, 71, 7, purple, 40, false)
        draw_circle(51, 71, 4, blue, 50, false)
        plot(51, 71, cyan, 65)
        
        draw_circle(71, 71, 7, violet, 55, false)
        draw_circle(71, 71, 4, sky_blue, 65, false)
        plot(71, 71, white, 80)

    # ----------------------------------------------------------
    # CEL 4: RED/PINK - Triangles
    # ----------------------------------------------------------
    sprite_cel(4)
        draw_polygon(11, 11, 7, 3, red, 50, 0, false)
        draw_polygon(11, 11, 3, 3, pink, 60, 180, true)
        
        draw_polygon(31, 11, 7, 3, pink, 45, 180, false)
        draw_polygon(31, 11, 3, 3, red, 55, 0, true)
        
        draw_polygon(51, 11, 7, 3, red, 50, 0, false)
        draw_polygon(51, 11, 3, 3, pink, 60, 180, true)
        
        draw_polygon(71, 11, 7, 3, pink, 45, 180, false)
        draw_polygon(71, 11, 3, 3, red, 55, 0, true)
        
        draw_polygon(11, 31, 7, 3, pink, 45, 180, false)
        draw_polygon(11, 31, 3, 3, red, 55, 0, true)
        
        draw_polygon(31, 31, 7, 3, coral, 55, 0, false)
        draw_polygon(31, 31, 3, 3, white, 70, 180, true)
        
        draw_polygon(51, 31, 7, 3, pink, 45, 180, false)
        draw_polygon(51, 31, 3, 3, red, 55, 0, true)
        
        draw_polygon(71, 31, 7, 3, coral, 55, 0, false)
        draw_polygon(71, 31, 3, 3, white, 70, 180, true)
        
        draw_polygon(11, 51, 7, 3, red, 50, 0, false)
        draw_polygon(11, 51, 3, 3, pink, 60, 180, true)
        
        draw_polygon(31, 51, 7, 3, pink, 45, 180, false)
        draw_polygon(31, 51, 3, 3, red, 55, 0, true)
        
        draw_polygon(51, 51, 7, 3, red, 50, 0, false)
        draw_polygon(51, 51, 3, 3, pink, 60, 180, true)
        
        draw_polygon(71, 51, 7, 3, pink, 45, 180, false)
        draw_polygon(71, 51, 3, 3, red, 55, 0, true)
        
        draw_polygon(11, 71, 7, 3, pink, 45, 180, false)
        draw_polygon(11, 71, 3, 3, red, 55, 0, true)
        
        draw_polygon(31, 71, 7, 3, coral, 55, 0, false)
        draw_polygon(31, 71, 3, 3, white, 70, 180, true)
        
        draw_polygon(51, 71, 7, 3, pink, 45, 180, false)
        draw_polygon(51, 71, 3, 3, red, 55, 0, true)
        
        draw_polygon(71, 71, 7, 3, coral, 55, 0, false)
        draw_polygon(71, 71, 3, 3, white, 70, 180, true)

endsprite

sync_queue

# ============================================================
# ACTIVATE BACKGROUND
# ============================================================
set_background(geo_pattern, 0, 0)

sync_queue

# ============================================================
# ANIMATION VARIABLES
# ============================================================
v_frame = 0

# Position accumulators
v_acc_x = 0.0
v_acc_y = 0.0

# Phase angles for sine wave movement
v_phase_x1 = 0.0
v_phase_x2 = 1.5
v_phase_y1 = 0.8
v_phase_y2 = 2.2

# Frequencies for direction
v_freq_x1 = 0.010
v_freq_x2 = 0.018
v_freq_y1 = 0.012
v_freq_y2 = 0.008

# Speed modulation - very slow cycle
v_speed_phase = 0.0
v_speed_freq = 0.003

# Speed range
v_speed_slow = 0.4
v_speed_fast = 2.5

# Cel transition
v_cel_timer = 0
v_cel_duration = 300
v_current_cel = 0
v_total_cels = 5

# Center polygon
v_poly_rotation = 0.0
v_poly_rot_speed = 0.5
v_poly_size_phase = 0.0
v_poly_size_speed = 0.02
v_poly_min_size = 6
v_poly_max_size = 14
v_poly_sides = 3.0
v_poly_sides_speed = 0.008
v_poly_sides_dir = 1

# ============================================================
# MAIN ANIMATION LOOP
# ============================================================
while 1 then
    begin_frame(false)
    
    # -----------------------------------------
    # Update phase angles
    # -----------------------------------------
    v_phase_x1 = v_phase_x1 + v_freq_x1
    v_phase_x2 = v_phase_x2 + v_freq_x2
    v_phase_y1 = v_phase_y1 + v_freq_y1
    v_phase_y2 = v_phase_y2 + v_freq_y2
    
    if v_phase_x1 > 6.28318 then
        v_phase_x1 = v_phase_x1 - 6.28318
    endif
    if v_phase_x2 > 6.28318 then
        v_phase_x2 = v_phase_x2 - 6.28318
    endif
    if v_phase_y1 > 6.28318 then
        v_phase_y1 = v_phase_y1 - 6.28318
    endif
    if v_phase_y2 > 6.28318 then
        v_phase_y2 = v_phase_y2 - 6.28318
    endif
    
    # -----------------------------------------
    # Calculate speed (slow cycle, more time at low speed)
    # abs(sin) spends more time near zero as it crosses
    # -----------------------------------------
    v_speed_phase = v_speed_phase + v_speed_freq
    if v_speed_phase > 6.28318 then
        v_speed_phase = v_speed_phase - 6.28318
    endif
    
    v_speed_factor = abs(sin(v_speed_phase))
    v_current_speed = v_speed_slow + v_speed_factor * (v_speed_fast - v_speed_slow)
    
    # -----------------------------------------
    # Calculate velocity direction and apply speed
    # -----------------------------------------
    v_vel_x = sin(v_phase_x1) * 1.5 + sin(v_phase_x2) * 1.0
    v_vel_x = v_vel_x * v_current_speed * 0.4
    
    v_vel_y = sin(v_phase_y1) * 1.2 + sin(v_phase_y2) * 0.8
    v_vel_y = v_vel_y * v_current_speed * 0.4
    
    # -----------------------------------------
    # Accumulate and apply scroll
    # -----------------------------------------
    v_acc_x = v_acc_x + v_vel_x
    v_acc_y = v_acc_y + v_vel_y
    
    v_scroll_x = 0
    v_scroll_y = 0
    
    if v_acc_x >= 1 then
        v_scroll_x = int(v_acc_x)
        v_acc_x = v_acc_x - v_scroll_x
    endif
    if v_acc_x <= -1 then
        v_scroll_x = int(v_acc_x)
        v_acc_x = v_acc_x - v_scroll_x
    endif
    if v_acc_y >= 1 then
        v_scroll_y = int(v_acc_y)
        v_acc_y = v_acc_y - v_scroll_y
    endif
    if v_acc_y <= -1 then
        v_scroll_y = int(v_acc_y)
        v_acc_y = v_acc_y - v_scroll_y
    endif
    
    # -----------------------------------------
    # Cel transition timer
    # -----------------------------------------
    v_cel_timer = v_cel_timer + 1
    if v_cel_timer >= v_cel_duration then
        v_cel_timer = 0
        v_current_cel = v_current_cel + 1
        if v_current_cel >= v_total_cels then
            v_current_cel = 0
        endif
    endif
    
    # -----------------------------------------
    # Apply scroll with current cel
    # Always nudge (even 0,0) to update cel smoothly
    # -----------------------------------------
    nudge_background(v_scroll_x, v_scroll_y, 0, v_current_cel)
    
    # -----------------------------------------
    # Center polygon - rotating, pulsing, morphing
    # -----------------------------------------
    # Update rotation (slow spin)
    v_poly_rotation = v_poly_rotation + v_poly_rot_speed
    if v_poly_rotation >= 360 then
        v_poly_rotation = v_poly_rotation - 360
    endif
    
    # Update size (pulse)
    v_poly_size_phase = v_poly_size_phase + v_poly_size_speed
    if v_poly_size_phase > 6.28318 then
        v_poly_size_phase = v_poly_size_phase - 6.28318
    endif
    v_poly_size_factor = (sin(v_poly_size_phase) + 1) * 0.5
    v_poly_size = v_poly_min_size + v_poly_size_factor * (v_poly_max_size - v_poly_min_size)
    
    # Update sides (3 to 7 to 3)
    v_poly_sides = v_poly_sides + v_poly_sides_speed * v_poly_sides_dir
    if v_poly_sides >= 7 then
        v_poly_sides = 7
        v_poly_sides_dir = -1
    endif
    if v_poly_sides <= 3 then
        v_poly_sides = 3
        v_poly_sides_dir = 1
    endif
    
    # Draw the polygon (filled, centered at 32,32)
    v_poly_s = int(v_poly_sides)
    v_poly_r = int(v_poly_rotation)
    v_poly_sz = int(v_poly_size)
    
    # Outer glow
    draw_polygon(32, 32, v_poly_sz + 2, v_poly_s, white, 25, v_poly_r, false)
    
    # Main filled shape
    draw_polygon(32, 32, v_poly_sz, v_poly_s, white, 70, v_poly_r, true)
    
    # Inner accent
    v_inner_sz = int(v_poly_size * 0.4)
    if v_inner_sz > 1 then
        draw_polygon(32, 32, v_inner_sz, v_poly_s, yellow, 90, v_poly_r + 30, true)
    endif
    
    # Center dot
    plot(32, 32, white, 100)
    
    end_frame
    
    v_frame = v_frame + 1
    if v_frame > 50000 then
        v_frame = 0
    endif
endwhile
