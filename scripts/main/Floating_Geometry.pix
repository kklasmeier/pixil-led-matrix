        plot(31, 31, yellow, 80)
        
        draw_rectangle(44, 24, 14, 14, magenta, 45, false)
        draw_circle(51, 31, 4, cyan, 55, false)
        plot(51, 31, white, 70)
        
        draw_rectangle(64, 24, 14, 14, cyan, 55, false)
        draw_circle(71, 31, 4, magenta, 65, false)
        plot(71, 31, yellow, 80)
        
        draw_rectangle(4, 44, 14, 14, cyan, 50, false)
        draw_circle(11, 51, 4, magenta, 60, false)
        plot(11, 51, white, 75)
        
        draw_rectangle(24, 44, 14, 14, magenta, 45, false)
        draw_circle(31, 51, 4, cyan, 55, false)
        plot(31, 51, white, 70)
        
        draw_rectangle(44, 44, 14, 14, cyan, 50, false)
        draw_circle(51, 51, 4, magenta, 60, false)
        plot(51, 51, white, 75)
        
        draw_rectangle(64, 44, 14, 14, magenta, 45, false)
        draw_circle(71, 51, 4, cyan, 55, false)
        plot(71, 51, white, 70)
        
        draw_rectangle(4, 64, 14, 14, magenta, 45, false)
        draw_circle(11, 71, 4, cyan, 55, false)
