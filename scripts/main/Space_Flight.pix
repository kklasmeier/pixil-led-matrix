# --- Layer 1: Far nebula (112x112) - distant large gas formations ---
define_sprite(bg_nebula_far, 112, 112)
    # Large dim cloud masses - deep background gas
    draw_ellipse(15, 20, 14, 7, indigo, 11, true, 25)
    draw_ellipse(22, 17, 8, 4, purple, 8, true, -15)
    draw_ellipse(65, 45, 16, 8, navy, 10, true, 40)
    draw_ellipse(74, 42, 9, 5, blue, 7, true, -20)
    draw_ellipse(35, 80, 12, 6, violet, 10, true, 50)
    draw_ellipse(95, 18, 10, 6, indigo, 9, true, -35)
    draw_ellipse(10, 60, 13, 5, purple, 8, true, 65)
    draw_ellipse(55, 100, 11, 6, navy, 9, true, 15)
    # Dim embedded stars
    plot(19, 21, cyan, 20)
    plot(68, 44, sky_blue, 18)
    plot(38, 82, lavender, 22)
    plot(97, 20, cyan, 15)
endsprite

# --- Layer 2: Near nebula (80x80) - closer bright wisps ---
define_sprite(bg_nebula_near, 80, 80)
    # Smaller brighter cloud wisps - closer gas tendrils
    draw_ellipse(18, 12, 7, 4, violet, 18, true, 30)
    draw_ellipse(22, 10, 4, 2, magenta, 14, true, -10)
    draw_ellipse(55, 50, 8, 4, purple, 16, true, -25)
    draw_ellipse(60, 48, 5, 3, indigo, 12, true, 15)
    draw_ellipse(12, 55, 6, 3, violet, 15, true, 45)
    draw_ellipse(68, 20, 7, 4, magenta, 14, true, -40)
    draw_ellipse(35, 70, 8, 4, purple, 16, true, 20)
    draw_ellipse(72, 65, 6, 3, indigo, 13, true, -30)
    # Brighter accent stars caught in wisps
    plot(20, 13, cyan, 35)
    plot(57, 51, sky_blue, 30)
    plot(14, 57, lavender, 40)
    plot(70, 22, cyan, 28)
endsprite

