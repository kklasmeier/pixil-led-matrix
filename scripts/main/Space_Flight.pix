# space_cruise.pxl
# Cinematic spaceship cruising through space
# Ship stays near center, offset opposite to heading for "road ahead" perspective
# Backgrounds scroll in heading direction at different speeds for 3D depth
# Runs forever - press spacebar to skip to next script or Ctrl+C to quit

throttle(0.3)

