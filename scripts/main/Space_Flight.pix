# =========================================
# SHIP SPRITE - 8 directional cels
# =========================================
define_sprite(ship, 7, 7)
    # Cel 0: East -->
    sprite_cel(0)
        plot(6, 3, white, 100)
        plot(5, 2, cyan, 90)
        plot(5, 3, cyan, 100)
        plot(5, 4, cyan, 90)
        draw_line(1, 3, 4, 3, white, 85)
        draw_line(2, 2, 4, 2, sky_blue, 65)
        draw_line(2, 4, 4, 4, sky_blue, 65)
        plot(0, 1, orange, 70)
        plot(0, 5, orange, 70)

    # Cel 1: Northeast
    sprite_cel(1)
        plot(6, 0, white, 100)
        plot(5, 0, cyan, 90)
        plot(5, 1, cyan, 100)
        plot(6, 1, cyan, 90)
        draw_line(2, 4, 4, 2, white, 85)
        draw_line(1, 3, 3, 1, sky_blue, 65)
        draw_line(3, 5, 5, 3, sky_blue, 65)
        plot(0, 5, orange, 70)
        plot(1, 6, orange, 70)

    # Cel 2: North ^
    sprite_cel(2)
        plot(3, 0, white, 100)
        plot(2, 1, cyan, 90)
        plot(3, 1, cyan, 100)
        plot(4, 1, cyan, 90)
        draw_line(3, 2, 3, 5, white, 85)
        draw_line(2, 2, 2, 4, sky_blue, 65)
        draw_line(4, 2, 4, 4, sky_blue, 65)
        plot(1, 6, orange, 70)
        plot(5, 6, orange, 70)

    # Cel 3: Northwest
    sprite_cel(3)
        plot(0, 0, white, 100)
        plot(0, 1, cyan, 90)
        plot(1, 0, cyan, 90)
        plot(1, 1, cyan, 100)
        draw_line(2, 2, 4, 4, white, 85)
        draw_line(1, 3, 3, 5, sky_blue, 65)
        draw_line(3, 1, 5, 3, sky_blue, 65)
        plot(6, 5, orange, 70)
        plot(5, 6, orange, 70)

    # Cel 4: West <--
    sprite_cel(4)
        plot(0, 3, white, 100)
        plot(1, 2, cyan, 90)
        plot(1, 3, cyan, 100)
        plot(1, 4, cyan, 90)
        draw_line(2, 3, 5, 3, white, 85)
        draw_line(2, 2, 4, 2, sky_blue, 65)
        draw_line(2, 4, 4, 4, sky_blue, 65)
        plot(6, 1, orange, 70)
        plot(6, 5, orange, 70)

    # Cel 5: Southwest
    sprite_cel(5)
        plot(0, 6, white, 100)
        plot(0, 5, cyan, 90)
        plot(1, 5, cyan, 100)
        plot(1, 6, cyan, 90)
        draw_line(2, 4, 4, 2, white, 85)
        draw_line(1, 3, 3, 1, sky_blue, 65)
        draw_line(3, 5, 5, 3, sky_blue, 65)
        plot(5, 0, orange, 70)
        plot(6, 1, orange, 70)

    # Cel 6: South v
    sprite_cel(6)
        plot(3, 6, white, 100)
        plot(2, 5, cyan, 90)
        plot(3, 5, cyan, 100)
        plot(4, 5, cyan, 90)
        draw_line(3, 1, 3, 4, white, 85)
        draw_line(2, 2, 2, 4, sky_blue, 65)
        draw_line(4, 2, 4, 4, sky_blue, 65)
        plot(1, 0, orange, 70)
        plot(5, 0, orange, 70)

    # Cel 7: Southeast
    sprite_cel(7)
        plot(6, 6, white, 100)
        plot(5, 5, cyan, 100)
        plot(5, 6, cyan, 90)
        plot(6, 5, cyan, 90)
        draw_line(2, 2, 4, 4, white, 85)
        draw_line(1, 3, 3, 5, sky_blue, 65)
        draw_line(3, 1, 5, 3, sky_blue, 65)
        plot(0, 1, orange, 70)
        plot(1, 0, orange, 70)
endsprite

# =========================================
# ACTIVATE BACKGROUNDS
# =========================================
set_background(bg_stars, 0)
set_background(bg_nebula_far, 1)
set_background(bg_nebula_near, 2)
set_background(bg_dust, 3)

# =========================================
# FLIGHT VARIABLES
# =========================================
v_heading = 0.0
v_turn_rate = 0.0
v_speed = 2.2

# Center of display
v_cx = 32
v_cy = 32

# Perspective offset strength (how far ship drifts from center)
v_offset_strength = 14

# Scroll accumulators
v_acc_star_x = 0.0
v_acc_star_y = 0.0
v_acc_nfar_x = 0.0
v_acc_nfar_y = 0.0
v_acc_nnear_x = 0.0
v_acc_nnear_y = 0.0
v_acc_dust_x = 0.0
v_acc_dust_y = 0.0

# Frame counter
v_frame = 0

# =========================================
# SHOW SHIP
# =========================================
show_sprite(ship, v_cx, v_cy, 0, 10, 0)

# =========================================
# MAIN LOOP - RUNS FOREVER
# =========================================
v_running = 1
while v_running == 1 then

    begin_frame(true)

    # --- Smooth heading change ---
    # Turn rate oscillates gently using layered sine waves
    # This creates long sweeping arcs with gentle direction changes
    v_turn_rate = sin(radians(v_frame * 0.47)) * 1.2 + sin(radians(v_frame * 0.13)) * 0.6 + sin(radians(v_frame * 1.1)) * 0.3

    v_heading = v_heading + v_turn_rate

    # Normalize heading 0-360
    if v_heading >= 360 then
        v_heading = v_heading - 360
    endif
    if v_heading < 0 then
        v_heading = v_heading + 360
    endif

    v_heading_rad = radians(v_heading)

    # --- Velocity vector (world scrolls this direction) ---
    v_vx = cos(v_heading_rad) * v_speed
    v_vy = sin(v_heading_rad) * v_speed

    # --- Ship screen position: center minus heading offset ---
    # Ship drifts opposite to heading so more space is visible ahead
    v_ship_x = v_cx - cos(v_heading_rad) * v_offset_strength
    v_ship_y = v_cy - sin(v_heading_rad) * v_offset_strength

    # Clamp to safe area
    v_ship_x = max(3, min(57, v_ship_x))
    v_ship_y = max(3, min(57, v_ship_y))

    # --- Pick ship cel (8 directions) ---
    # Map heading to cel: 0=E, 1=NE, 2=N, 3=NW, 4=W, 5=SW, 6=S, 7=SE
    # Each cel covers 45 degrees, offset by 22.5 so cel 0 centers on 0°
    v_cel_angle = v_heading + 22.5
    if v_cel_angle >= 360 then
        v_cel_angle = v_cel_angle - 360
    endif
    v_cel = int(v_cel_angle / 45)
    if v_cel > 7 then
        v_cel = 0
    endif

    # Pixil convention: positive Y is down on screen
    # So heading 0° = east (cel 0), 90° = south (cel 6), etc.
    # Remap: 0=E, 1=SE, 2=S, 3=SW, 4=W, 5=NW, 6=N, 7=NE
    # But our cels are: 0=E, 1=NE, 2=N, 3=NW, 4=W, 5=SW, 6=S, 7=SE
    # Need to mirror Y: cel_remap[raw] -> display
    # raw 0(E)->0, 1(ESE)->7(SE), 2(S)->6(S), 3(SSW)->5(SW), 4(W)->4, 5(WNW)->3(NW), 6(N)->2(N), 7(NNE)->1(NE)
    v_display_cel = 0
    if v_cel == 0 then
        v_display_cel = 0
    endif
    if v_cel == 1 then
        v_display_cel = 7
    endif
    if v_cel == 2 then
        v_display_cel = 6
    endif
    if v_cel == 3 then
        v_display_cel = 5
    endif
    if v_cel == 4 then
        v_display_cel = 4
    endif
    if v_cel == 5 then
        v_display_cel = 3
    endif
    if v_cel == 6 then
        v_display_cel = 2
    endif
    if v_cel == 7 then
        v_display_cel = 1
    endif

    move_sprite(ship, v_ship_x, v_ship_y, 0, v_display_cel)

    # --- Parallax background scrolling (4 layers) ---
    # World scrolls in heading direction (ship flies forward)
    # Layer 0 (far stars): 0.12x - barely drifts
    v_acc_star_x = v_acc_star_x + v_vx * 0.12
    v_acc_star_y = v_acc_star_y + v_vy * 0.12

    # Layer 1 (far nebula): 0.35x - distant gas
    v_acc_nfar_x = v_acc_nfar_x + v_vx * 0.35
    v_acc_nfar_y = v_acc_nfar_y + v_vy * 0.35

    # Layer 2 (near nebula): 0.7x - closer wisps
    v_acc_nnear_x = v_acc_nnear_x + v_vx * 0.7
    v_acc_nnear_y = v_acc_nnear_y + v_vy * 0.7

    # Layer 3 (dust): 1.3x - close particles streak past
    v_acc_dust_x = v_acc_dust_x + v_vx * 1.3
    v_acc_dust_y = v_acc_dust_y + v_vy * 1.3

    # Set absolute offsets from accumulators
    set_background_offset(int(v_acc_star_x), int(v_acc_star_y), 0, 0)
    set_background_offset(int(v_acc_nfar_x), int(v_acc_nfar_y), 1, 0)
    set_background_offset(int(v_acc_nnear_x), int(v_acc_nnear_y), 2, 0)
    set_background_offset(int(v_acc_dust_x), int(v_acc_dust_y), 3, 0)

    end_frame
    rest(0.018)

    v_frame = v_frame + 1

    # Prevent accumulator overflow (wrap periodically)
    # Background tiles seamlessly so this is invisible
    if v_frame - floor(v_frame / 10000) * 10000 == 0 then
        v_acc_star_x = v_acc_star_x - floor(v_acc_star_x / 128) * 128
        v_acc_star_y = v_acc_star_y - floor(v_acc_star_y / 128) * 128
        v_acc_nfar_x = v_acc_nfar_x - floor(v_acc_nfar_x / 112) * 112
        v_acc_nfar_y = v_acc_nfar_y - floor(v_acc_nfar_y / 112) * 112
        v_acc_nnear_x = v_acc_nnear_x - floor(v_acc_nnear_x / 80) * 80
        v_acc_nnear_y = v_acc_nnear_y - floor(v_acc_nnear_y / 80) * 80
        v_acc_dust_x = v_acc_dust_x - floor(v_acc_dust_x / 80) * 80
        v_acc_dust_y = v_acc_dust_y - floor(v_acc_dust_y / 80) * 80
    endif

endwhile

hide_background
dispose_all_sprites()
clear()
